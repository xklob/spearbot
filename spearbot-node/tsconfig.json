{
  "compilerOptions": {
    "target": "EsNext",
    "module": "ESNext",
    "lib": ["ES2023"],
    "types": ["node", "vitest"],
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "strict": true,
    "skipLibCheck": true
  }
}
